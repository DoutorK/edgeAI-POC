# Backend
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/edgeai
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=legal-docs
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000
LLM_PROVIDER=openai
# Valores aceitos: openai | gemini | local
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=512
LLM_CLEANED_TEXT_MAX_CHARS=6000
LLM_MAX_ITEMS_PER_LIST=25
LLM_MAX_ITEM_CHARS=120
LLM_MAX_SNIPPETS=8
LLM_MAX_SNIPPETS_TOTAL_CHARS=1400

# Edge
BACKEND_URL=http://localhost:8000
REQUEST_TIMEOUT_SEC=45
TESSERACT_CMD=
SPACY_MODEL=pt_core_news_sm
